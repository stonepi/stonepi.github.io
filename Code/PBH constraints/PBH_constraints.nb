Cell[CellGroupData[{

Cell["Explain OGLE 6 events by planet-mass PBHs", "Subsection",
 CellChangeTimes->{{3.983698156308972*^9, 3.983698159357376*^9}, {
  3.98369818949886*^9, 3.9836981983227367`*^9}, {3.983698230076865*^9, 
  3.9836982387198763`*^9}},ExpressionUUID->"dc6e1b9d-bd8b-4b9f-8d3a-\
44700a4857e0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
     "The", " ", "contour", " ", "is", " ", "a", " ", "combination", " ", 
      "of", " ", "OGLE", " ", "6", " ", "events", " ", 
      RowBox[{"(", "1707.07634", ")"}], " ", "and", " ", "the", " ", 
      "Subaru"}], "-", 
     RowBox[{"HSC", " ", 
      RowBox[{"(", "1701.02151", ")"}], " ", "result"}]}], ",", " ", 
    RowBox[{"given", " ", "by", " ", 
     RowBox[{"1901.07120", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"contourFile2", "=", "\"\<OGLEevent.csv\>\""}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"raw2", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"contourFile2", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pts2", "=", 
     RowBox[{"Cases", "[", 
      RowBox[{"raw2", ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x_", "?", "NumericQ"}], ",", 
          RowBox[{"y_", "?", "NumericQ"}]}], "}"}], "\[RuleDelayed]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"N", "[", "x", "]"}], ",", 
          RowBox[{"N", "[", "y", "]"}]}], "}"}]}], ",", "Infinity"}], "]"}]}],
     ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"logPts", "=", 
     RowBox[{"Log", "/@", "pts2"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"center", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Mean", "[", 
        RowBox[{"logPts", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], ",", 
       RowBox[{"Mean", "[", 
        RowBox[{"logPts", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ordered", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{"logPts", ",", 
       RowBox[{
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", 
           RowBox[{"center", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "-", 
           RowBox[{"center", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "&"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"poly5", "=", 
     RowBox[{"Polygon", "@", 
      RowBox[{"Append", "[", 
       RowBox[{"ordered", ",", 
        RowBox[{"First", "[", "ordered", "]"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"ogle2", "=", 
    RowBox[{"Graphics", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Opacity", "[", "0.30", "]"}], ",", "Purple", ",", "poly5"}],
         "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Purple", ",", "Dashed", ",", "Thick", ",", 
         RowBox[{"Line", "[", 
          RowBox[{"poly5", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
         RowBox[{"Text", "[", 
          RowBox[{
           RowBox[{"Rotate", "[", 
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{"\"\<O6\>\"", ",", 
               RowBox[{"FontFamily", "\[Rule]", "\"\<Times\>\""}], ",", 
               RowBox[{"FontSize", "\[Rule]", "16"}], ",", "White"}], "]"}], 
             ",", 
             RowBox[{
              RowBox[{"-", "30"}], " ", "Degree"}]}], "]"}], ",", "center"}], 
          "]"}]}], "}"}]}], "}"}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.980241873383232*^9, 3.9802418801268177`*^9}, {
   3.980339174336299*^9, 3.980339249861418*^9}, {3.980664248447111*^9, 
