       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
         "\"\<\!\(\*SubscriptBox[\(M\), \(PBH\)]\)/\!\(\*SubscriptBox[\(M\), \
\(\[CircleDot]\)]\)\>\"", ",", 
          "\"\<\!\(\*SubscriptBox[\(f\), \(PBH\)]\)(\!\(\*SubscriptBox[\(M\), \
\(PBH\)]\))\>\""}], "}"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"SubaruHSC", " ", "null", " ", "result", " ", "from", " ", 
     RowBox[{"2602.05840", "."}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SubaruNull", "=", 
     RowBox[{"Import", "[", "\"\<SubaruNull.csv\>\"", "]"}]}], ";"}], 
