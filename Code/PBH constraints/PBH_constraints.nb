 RowBox[{
  RowBox[{"logPts", "=", 
   RowBox[{"Log", "/@", "pts3"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"center", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mean", "[", 
      RowBox[{"logPts", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{"Mean", "[", 
      RowBox[{"logPts", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ordered", "=", 
   RowBox[{"SortBy", "[", 
    RowBox[{"logPts", ",", 
     RowBox[{
      RowBox[{"ArcTan", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "-", 
         RowBox[{"center", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "-", 
         RowBox[{"center", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"poly7", "=", 
   RowBox[{"Polygon", "@", 
    RowBox[{"Append", "[", 
     RowBox[{"ordered", ",", 
      RowBox[{"First", "[", "ordered", "]"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ogle3", "=", 
  RowBox[{"Graphics", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Opacity", "[", "0.30", "]"}], ",", "Gray", ",", "poly7"}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"Gray", ",", "Thick", ",", 
       RowBox[{"Line", "[", 
        RowBox[{"poly7", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{
         RowBox[{"Rotate", "[", 
          RowBox[{
           RowBox[{"Style", "[", 
            RowBox[{"\"\<O6\>\"", ",", 
             RowBox[{"FontFamily", "\[Rule]", "\"\<Times\>\""}], ",", 
             RowBox[{"FontSize", "\[Rule]", "16"}], ",", "White"}], "]"}], 
           ",", 
           RowBox[{
            RowBox[{"-", "40"}], " ", "Degree"}]}], "]"}], ",", "center"}], 
        "]"}]}], "}"}]}], "}"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.98104083300159*^9, 3.981040896727894*^9}, 
   3.981040930551599*^9, {3.98104101104322*^9, 3.98104105331434*^9}, {
