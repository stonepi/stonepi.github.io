Cell[CellGroupData[{

Cell["Subaru-HSC suggested PBH from all 4 secured events", "Subsection",
 CellChangeTimes->{{3.983697967381465*^9, 
  3.983698033630999*^9}},ExpressionUUID->"5cd7fee3-de4d-4f92-a9a2-\
154d416c9223"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"S4B", "=", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\<S4B.csv\>\"", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pts", "=", 
   RowBox[{"Cases", "[", 
    RowBox[{"S4B", ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x_", "?", "NumericQ"}], ",", 
        RowBox[{"y_", "?", "NumericQ"}]}], "}"}], "\[RuleDelayed]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"N", "[", "x", "]"}], ",", 
        RowBox[{"N", "[", "y", "]"}]}], "}"}]}], ",", "Infinity"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"logPts", "=", 
   RowBox[{"Log", "/@", "pts"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"center", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mean", "[", 
      RowBox[{"logPts", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{"Mean", "[", 
      RowBox[{"logPts", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ordered", "=", 
   RowBox[{"SortBy", "[", 
    RowBox[{"logPts", ",", 
     RowBox[{
      RowBox[{"ArcTan", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "-", 
         RowBox[{"center", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "-", 
         RowBox[{"center", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"polyS4B", "=", 
   RowBox[{"Polygon", "@", 
    RowBox[{"Append", "[", 
     RowBox[{"ordered", ",", 
      RowBox[{"First", "[", "ordered", "]"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s4b", "=", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Opacity", "[", "0.10", "]"}], ",", "Red", ",", "polyS4B"}], 
      "}"}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"S4A", "=", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\<S4A.csv\>\"", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pts2", "=", 
   RowBox[{"Cases", "[", 
    RowBox[{"S4A", ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x_", "?", "NumericQ"}], ",", 
        RowBox[{"y_", "?", "NumericQ"}]}], "}"}], "\[RuleDelayed]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"N", "[", "x", "]"}], ",", 
        RowBox[{"N", "[", "y", "]"}]}], "}"}]}], ",", "Infinity"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"logPts", "=", 
   RowBox[{"Log", "/@", "pts2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"center", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mean", "[", 
      RowBox[{"logPts", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{"Mean", "[", 
      RowBox[{"logPts", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ordered", "=", 
   RowBox[{"SortBy", "[", 
    RowBox[{"logPts", ",", 
     RowBox[{
      RowBox[{"ArcTan", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "-", 
         RowBox[{"center", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "-", 
         RowBox[{"center", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"polyS4A", "=", 
   RowBox[{"Polygon", "@", 
    RowBox[{"Append", "[", 
     RowBox[{"ordered", ",", 
      RowBox[{"First", "[", "ordered", "]"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s4a", "=", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.30", "]"}], ",", "Red", ",", "polyS4A"}], 
       "}"}], ",", 
      RowBox[{"Text", "[", 
       RowBox[{
        RowBox[{"Rotate", "[", 
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{"\"\<S4\>\"", ",", 
            RowBox[{"FontFamily", "\[Rule]", "\"\<Times\>\""}], ",", 
            RowBox[{"FontSize", "\[Rule]", "14"}], ",", "White"}], "]"}], ",", 
          RowBox[{"45", " ", "Degree"}]}], "]"}], ",", 
        RowBox[{"center", "+", 
         RowBox[{"{", 
          RowBox[{"0.15", ",", 
           RowBox[{"-", "0.2"}]}], "}"}]}]}], "]"}]}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"s4", "=", 
  RowBox[{"Show", "[", 
   RowBox[{"s4a", ",", "s4b"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9802426156856003`*^9, 3.980242703490548*^9}, {
