Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "The", " ", "contour", " ", "used", " ", "OGLE", " ", "6", " ", "events", 
     " ", 
     RowBox[{"(", "1707.07634", ")"}], " ", "only"}], ",", " ", 
    RowBox[{"also", " ", "given", " ", "by", " ", 
     RowBox[{"1901.07120", ".", " ", "\[IndentingNewLine]", 
      RowBox[{"Note", ":", " ", 
       RowBox[{
        RowBox[{"As", " ", "Subaru"}], "-", 
        RowBox[{"HSC", " ", "already", " ", "observed", " ", "ultra"}], "-", 
        RowBox[{
        "short", " ", "timescale", " ", "microlensing", " ", "events", " ", 
         "in", " ", "2602.05840"}]}]}]}]}], ",", " ", 
    RowBox[{
     RowBox[{"the", " ", "contour", " ", "above", " ", 
      RowBox[{"(", "O6", ")"}], " ", "can", " ", "not", " ", "co"}], "-", 
     RowBox[{"exist", " ", "with", " ", "the", " ", "Subaru"}], "-", 
     RowBox[{"HSC", " ", "contours", " ", "S12", " ", "and", " ", 
      RowBox[{"S4", "."}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"contourFile3", "=", "\"\<ogle2.csv\>\""}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"raw3", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"contourFile3", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pts3", "=", 
     RowBox[{"Cases", "[", 
      RowBox[{"raw3", ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x_", "?", "NumericQ"}], ",", 
          RowBox[{"y_", "?", "NumericQ"}]}], "}"}], "\[RuleDelayed]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"N", "[", "x", "]"}], ",", 
          RowBox[{"N", "[", "y", "]"}]}], "}"}]}], ",", "Infinity"}], "]"}]}],
     ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"logPts", "=", 
     RowBox[{"Log", "/@", "pts3"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"center", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Mean", "[", 
        RowBox[{"logPts", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], ",", 
       RowBox[{"Mean", "[", 
        RowBox[{"logPts", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ordered", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{"logPts", ",", 
       RowBox[{
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", 
           RowBox[{"center", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "-", 
           RowBox[{"center", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "&"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"poly7", "=", 
     RowBox[{"Polygon", "@", 
      RowBox[{"Append", "[", 
       RowBox[{"ordered", ",", 
        RowBox[{"First", "[", "ordered", "]"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"ogle3", "=", 
    RowBox[{"Graphics", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Opacity", "[", "0.30", "]"}], ",", "Gray", ",", "poly7"}], 
        "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Gray", ",", "Thick", ",", 
         RowBox[{"Line", "[", 
          RowBox[{"poly7", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
         RowBox[{"Text", "[", 
          RowBox[{
           RowBox[{"Rotate", "[", 
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{"\"\<O6\>\"", ",", 
               RowBox[{"FontFamily", "\[Rule]", "\"\<Times\>\""}], ",", 
               RowBox[{"FontSize", "\[Rule]", "16"}], ",", "White"}], "]"}], 
             ",", 
             RowBox[{
              RowBox[{"-", "40"}], " ", "Degree"}]}], "]"}], ",", "center"}], 
          "]"}]}], "}"}]}], "}"}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.98104083300159*^9, 3.981040896727894*^9}, 
