Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Customize", " ", 
    RowBox[{"legend", ".", " ", "Add"}], " ", "if", " ", 
    RowBox[{"needed", "."}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"shadowbox5", "[", "legend_", "]"}], ":=", 
     RowBox[{"Graphics", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Gray", ",", 
           RowBox[{"Rectangle", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0.03", ",", 
               RowBox[{"-", "0.03"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0.53", ",", "0.48"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"White", ",", 
           RowBox[{"EdgeForm", "[", "Gray", "]"}], ",", 
           RowBox[{"Rectangle", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0.50", ",", "0.51"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"Inset", "[", 
          RowBox[{"legend", ",", 
           RowBox[{"{", 
            RowBox[{"0.25", ",", "0.25"}], "}"}], ",", "Center"}], "]"}]}], 
        "}"}], ",", 
       RowBox[{"ImageSize", "\[Rule]", "125"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"pbhlegend5", "=", 
    RowBox[{"SwatchLegend", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "Red", ",", "Blue", ",", "Purple", ",", "Cyan", ",", "Green", ",", 
        "Gray"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<EG/GC \[Gamma]-ray\>\"", ",", "\"\<Subaru HSC\>\"", ",", 
        "\"\<OGLE-IV HC\>\"", ",", "\"\<OGLE-III+IV\>\"", ",", 
        "\"\<EROS/MACHO\>\"", ",", "\"\<Planck(disk)\>\""}], "}"}], ",", 
      RowBox[{"LegendMarkers", "\[Rule]", 
       RowBox[{"Graphics", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"EdgeForm", "[", "Black", "]"}], ",", 
          RowBox[{"Opacity", "[", "1", "]"}], ",", 
          RowBox[{"Rectangle", "[", "]"}]}], "}"}], "]"}]}], ",", 
      RowBox[{"LegendFunction", "\[Rule]", "shadowbox5"}], ",", 
      RowBox[{"LegendMargins", "\[Rule]", "1"}], ",", 
      RowBox[{"LabelStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"FontSize", "\[Rule]", "12"}], ",", 
         RowBox[{"FontFamily", "\[Rule]", "\"\<Times\>\""}]}], "}"}]}]}], 
     "]"}]}]}]}]], "Input",
