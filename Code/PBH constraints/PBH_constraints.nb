Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Subaru", "-", 
    RowBox[{"HSC", " ", "2017", " ", 
     RowBox[{"constraint", ":", " ", "1701.02151"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"HSC", "=", 
     RowBox[{"Import", "[", "\"\<SubaruHSC.csv\>\"", "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"hsc", "=", 
     RowBox[{"ListPlot", "[", 
      RowBox[{"HSC", ",", 
       RowBox[{"Joined", "\[Rule]", "True"}], ",", 
       RowBox[{"Frame", "\[Rule]", "True"}], ",", 
       RowBox[{"Filling", "\[Rule]", "Top"}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", "Blue"}], ",", 
       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
         "\"\<\!\(\*SubscriptBox[\(log\), \(10\)]\)(\!\(\*SubscriptBox[\(M\), \
\(PBH\)]\)/\!\(\*SubscriptBox[\(M\), \(\[CircleDot]\)]\))\>\"", ",", 
          "\"\<\!\(\*SubscriptBox[\(log\), \
\(10\)]\)(\!\(\*SubscriptBox[\(f\), \(PBH\)]\))\>\""}], "}"}]}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"HSC2", "=", 
     SuperscriptBox["10", "HSC"]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"hsc2", "=", 
     RowBox[{"ListLogLogPlot", "[", 
      RowBox[{"HSC2", ",", 
       RowBox[{"Joined", "\[Rule]", "True"}], ",", 
       RowBox[{"Frame", "\[Rule]", "True"}], ",", 
       RowBox[{"Filling", "\[Rule]", "None"}], ",", 
