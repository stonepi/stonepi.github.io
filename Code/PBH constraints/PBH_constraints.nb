Cell[CellGroupData[{

Cell["Subaru-HSC suggested PBH from all the 12 events", "Subsection",
 CellChangeTimes->{{3.983697967381465*^9, 
  3.983698007287467*^9}},ExpressionUUID->"550599b8-f318-40e8-aa26-\
9bd305a5831d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"S12B", "=", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\<S12B.csv\>\"", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pts", "=", 
   RowBox[{"Cases", "[", 
    RowBox[{"S12B", ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x_", "?", "NumericQ"}], ",", 
        RowBox[{"y_", "?", "NumericQ"}]}], "}"}], "\[RuleDelayed]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"N", "[", "x", "]"}], ",", 
        RowBox[{"N", "[", "y", "]"}]}], "}"}]}], ",", "Infinity"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"logPts1", "=", 
   RowBox[{"Log", "/@", "pts"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"center1", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mean", "[", 
      RowBox[{"logPts1", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{"Mean", "[", 
      RowBox[{"logPts1", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ordered", "=", 
   RowBox[{"SortBy", "[", 
    RowBox[{"logPts1", ",", 
     RowBox[{
      RowBox[{"ArcTan", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "-", 
         RowBox[{"center1", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "-", 
         RowBox[{"center1", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"polyS12B", "=", 
   RowBox[{"Polygon", "@", 
    RowBox[{"Append", "[", 
     RowBox[{"ordered", ",", 
      RowBox[{"First", "[", "ordered", "]"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s12b", "=", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.10", "]"}], ",", "Blue", ",", "polyS12B"}],
        "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", "Thick", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"polyS12B", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "}"}]}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"S12A", "=", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\<S12A.csv\>\"", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pts2", "=", 
   RowBox[{"Cases", "[", 
    RowBox[{"S12A", ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x_", "?", "NumericQ"}], ",", 
        RowBox[{"y_", "?", "NumericQ"}]}], "}"}], "\[RuleDelayed]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"N", "[", "x", "]"}], ",", 
        RowBox[{"N", "[", "y", "]"}]}], "}"}]}], ",", "Infinity"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"logPts2", "=", 
   RowBox[{"Log", "/@", "pts2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"center2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mean", "[", 
      RowBox[{"logPts2", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{"Mean", "[", 
      RowBox[{"logPts2", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ordered", "=", 
   RowBox[{"SortBy", "[", 
    RowBox[{"logPts2", ",", 
     RowBox[{
      RowBox[{"ArcTan", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "-", 
         RowBox[{"center2", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "-", 
         RowBox[{"center2", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"polyS12A", "=", 
   RowBox[{"Polygon", "@", 
    RowBox[{"Append", "[", 
     RowBox[{"ordered", ",", 
      RowBox[{"First", "[", "ordered", "]"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s12a", "=", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.50", "]"}], ",", "Blue", ",", "polyS12A"}],
        "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"polyS12A", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "}"}], ",", 
      RowBox[{"Text", "[", 
       RowBox[{
        RowBox[{"Rotate", "[", 
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{"\"\<S12\>\"", ",", 
            RowBox[{"FontFamily", "\[Rule]", "\"\<Times\>\""}], ",", 
            RowBox[{"FontSize", "\[Rule]", "14"}], ",", "White"}], "]"}], ",", 
          RowBox[{"45", " ", "Degree"}]}], "]"}], ",", "center2"}], "]"}]}], 
     "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"s12", "=", 
  RowBox[{"Show", "[", 
   RowBox[{"s12a", ",", "s12b", ",", 
    RowBox[{"Frame", "\[Rule]", "True"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9802426156856003`*^9, 3.980242703490548*^9}, {
   3.980242825808869*^9, 3.980242832404148*^9}, {3.980242928157996*^9, 
