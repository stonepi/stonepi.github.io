Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
  "contourFile2", "=", 
   "\"\</Users/SPi/Dropbox/Lecture Note on SGWB/data/OGLEevent.csv\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"raw2", "=", 
   RowBox[{"Import", "[", 
    RowBox[{"contourFile2", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pts2", "=", 
   RowBox[{"Cases", "[", 
    RowBox[{"raw2", ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x_", "?", "NumericQ"}], ",", 
        RowBox[{"y_", "?", "NumericQ"}]}], "}"}], "\[RuleDelayed]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"N", "[", "x", "]"}], ",", 
        RowBox[{"N", "[", "y", "]"}]}], "}"}]}], ",", "Infinity"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"logPts", "=", 
   RowBox[{"Log", "/@", "pts2"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"center", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mean", "[", 
      RowBox[{"logPts", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{"Mean", "[", 
      RowBox[{"logPts", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ordered", "=", 
   RowBox[{"SortBy", "[", 
    RowBox[{"logPts", ",", 
     RowBox[{
      RowBox[{"ArcTan", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "-", 
         RowBox[{"center", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "-", 
         RowBox[{"center", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"poly5", "=", 
   RowBox[{"Polygon", "@", 
    RowBox[{"Append", "[", 
     RowBox[{"ordered", ",", 
      RowBox[{"First", "[", "ordered", "]"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ogle2", "=", 
  RowBox[{"Graphics", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Opacity", "[", "0.30", "]"}], ",", "Purple", ",", "poly5"}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"Purple", ",", "Dashed", ",", "Thick", ",", 
       RowBox[{"Line", "[", 
        RowBox[{"poly5", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{
         RowBox[{"Rotate", "[", 
          RowBox[{
           RowBox[{"Style", "[", 
            RowBox[{"\"\<O6\>\"", ",", 
             RowBox[{"FontFamily", "\[Rule]", "\"\<Times\>\""}], ",", 
             RowBox[{"FontSize", "\[Rule]", "16"}], ",", "White"}], "]"}], 
           ",", 
           RowBox[{
            RowBox[{"-", "30"}], " ", "Degree"}]}], "]"}], ",", "center"}], 
        "]"}]}], "}"}]}], "}"}], "]"}]}]}], "Input",
