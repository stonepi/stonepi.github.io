     RowBox[{"Assuming", "'"}], 
     RowBox[{"gwModelData", "'"}], " ", "is", " ", "your", " ", 
     RowBox[{"{", 
      RowBox[{"freq", ",", "omega"}], "}"}], " ", "list"}], 
    "*)"}]}]}]], "Input",
