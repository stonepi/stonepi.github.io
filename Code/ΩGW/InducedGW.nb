Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "style", " ", "first", " ", "for", " ", 
    "cleaner", " ", "code"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"gwSignalStyle1", "=", 
     RowBox[{"Directive", "[", 
      RowBox[{"Blue", ",", 
       RowBox[{"AbsoluteThickness", "[", "4", "]"}], ",", 
