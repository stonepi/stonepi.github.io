Cell[BoxData[{
 RowBox[{
  RowBox[{"Method", "\[Rule]", "\"\<LocalAdaptive\>\""}], ";"}], "\n", 
 RowBox[{
  RowBox[{"GWarray", "=", 
   RowBox[{
    RowBox[{"ParallelArray", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"NIntegrate", "[", 
        RowBox[{
         RowBox[{"3", " ", 
          FractionBox[
           RowBox[{"Tuv", "[", 
            RowBox[{"u", ",", "v"}], "]"}], 
           RowBox[{
            SuperscriptBox["u", "2"], 
            SuperscriptBox["v", "2"]}]]}], ",", 
         RowBox[{"{", 
          RowBox[{"v", ",", 
           FractionBox["1", 
            RowBox[{"wid", " ", 
             RowBox[{"karray", "[", 
              RowBox[{"[", "#", "]"}], "]"}]}]], ",", 
           FractionBox["1", 
            RowBox[{"karray", "[", 
             RowBox[{"[", "#", "]"}], "]"}]]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"u", ",", 
           RowBox[{"Max", "[", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"1", "-", "v"}], "]"}], ",", 
             FractionBox["1", 
              RowBox[{"wid", " ", 
               RowBox[{"karray", "[", 
                RowBox[{"[", "#", "]"}], "]"}]}]]}], "]"}], ",", 
           RowBox[{"Min", "[", 
            RowBox[{
             RowBox[{"1", "+", "v"}], ",", 
             FractionBox["1", 
              RowBox[{"karray", "[", 
               RowBox[{"[", "#", "]"}], "]"}]]}], "]"}]}], "}"}], ",", 
         RowBox[{"PrecisionGoal", "\[Rule]", "10"}], ",", 
         RowBox[{"WorkingPrecision", "\[Rule]", "20"}]}], "]"}], "&"}], ",", 
      RowBox[{"Length", "[", "karray", "]"}]}], "]"}], "//", "Quiet"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.979815551299564*^9, 3.97981556361336*^9}, {
