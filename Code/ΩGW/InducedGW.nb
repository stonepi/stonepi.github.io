Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Tuv", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox["1", "4"], 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{
           RowBox[{"4", 
            SuperscriptBox["v", "2"]}], "-", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"1", "+", 
              SuperscriptBox["v", "2"], "-", 
              SuperscriptBox["u", "2"]}], ")"}], "2"]}], 
          RowBox[{"4", "u", " ", "v"}]], ")"}], "2"], 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{
           SuperscriptBox["u", "2"], "+", 
           SuperscriptBox["v", "2"], "-", "3"}], 
          RowBox[{"2", "u", " ", "v"}]], ")"}], "2"], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "2"}], "+", 
            RowBox[{
             FractionBox[
              RowBox[{
               SuperscriptBox["u", "2"], "+", 
               SuperscriptBox["v", "2"], "-", "3"}], 
              RowBox[{"2", " ", "u", " ", "v"}]], 
             RowBox[{"Log", "[", 
              RowBox[{"Abs", "[", 
               FractionBox[
                RowBox[{"3", "-", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{"u", "+", "v"}], ")"}], "2"]}], 
                RowBox[{"3", "-", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{"u", "-", "v"}], ")"}], "2"]}]], "]"}], "]"}]}]}], 
           ")"}], "2"], "+", 
         RowBox[{
          SuperscriptBox["\[Pi]", "2"], 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox[
             RowBox[{
              SuperscriptBox["u", "2"], "+", 
              SuperscriptBox["v", "2"], "-", "3"}], 
             RowBox[{"2", " ", "u", " ", "v"}]], ")"}], "2"], 
          RowBox[{"HeavisideTheta", "[", 
           RowBox[{"u", "+", "v", "-", 
            SqrtBox["3"]}], "]"}]}]}], ")"}]}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"u", "\[Rule]", "#1"}], ",", 
        RowBox[{"v", "\[Rule]", "#2"}]}], "}"}]}], "&"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"Tuv", "[", 
       RowBox[{
        FractionBox[
         RowBox[{"s", "+", "t"}], 
         SqrtBox["2"]], ",", 
        FractionBox[
         RowBox[{"s", "-", "t"}], 
         SqrtBox["2"]]}], "]"}], ",", 
      RowBox[{"Assumptions", "\[Rule]", 
       RowBox[{
        RowBox[{"s", ">", "0"}], "&&", 
        RowBox[{"t", "<", "1"}], "&&", 
        RowBox[{"t", ">", 
         RowBox[{"-", "1"}]}]}]}]}], "]"}], ";"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Tst", "=", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{"%", "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"s", "\[Rule]", "#1"}], ",", 
          RowBox[{"t", "\[Rule]", "#2"}]}], "}"}]}], "]"}], "&"}]}], ";"}], 
