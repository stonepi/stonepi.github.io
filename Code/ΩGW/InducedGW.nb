      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"freqFunc", "[", "temp_", "]"}], ":=", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", "g", "}"}], ",", 
         RowBox[{
          RowBox[{"g", "=", 
           RowBox[{"10", "^", 
            RowBox[{"gTInterp", "[", 
             RowBox[{"Log10", "[", "temp", "]"}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", 
             RowBox[{"(", 
              RowBox[{"2", " ", "Pi"}], ")"}]}], ")"}], "*", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"gs0", "/", "g"}], ")"}], "^", 
            RowBox[{"(", 
             RowBox[{"1", "/", "3"}], ")"}]}], "*", 
           RowBox[{"(", 
            RowBox[{"t0", "/", "temp"}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{"1.66", "*", 
             RowBox[{"Sqrt", "[", "g", "]"}], "*", 
             RowBox[{
              RowBox[{"temp", "^", "2"}], "/", "mpl"}]}], ")"}], "*", 
           "hzConv"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"bigTable", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Log10", "[", 
            RowBox[{"freqFunc", "[", "t", "]"}], "]"}], ",", 
           RowBox[{"gTInterp", "[", 
            RowBox[{"Log10", "[", "t", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", 
           RowBox[{"10", "^", 
            RowBox[{"Range", "[", 
             RowBox[{
              RowBox[{"-", "7"}], ",", "7", ",", "0.005"}], "]"}]}]}], 
          "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"fToGInterp", "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{"bigTable", ",", 
         RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"farray", "=", 
       RowBox[{"2", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "5"}]}], "*", 
        RowBox[{"Array", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"10", "^", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "5"}], "+", 
              RowBox[{"0.02", " ", 
               RowBox[{"(", 
                RowBox[{"#", "-", "1"}], ")"}]}]}], ")"}]}], "&"}], ",", 
          "301"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"10", "^", 
          RowBox[{"fToGInterp", "[", 
           RowBox[{"Log10", "[", "#", "]"}], "]"}]}], "&"}], ",", "farray"}], 
       "]"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
