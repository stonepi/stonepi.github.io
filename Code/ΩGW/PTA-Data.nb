Cell[BoxData[
 RowBox[{"PTA1", "=", 
  RowBox[{"Show", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ListLogLogPlot", "[", 
     RowBox[{"dat", ",", 
      RowBox[{"Joined", "->", "True"}]}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"ImageSize", "\[Rule]", "800"}], ",", 
    RowBox[{"Frame", "\[Rule]", "True"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Log", "@", 
        RowBox[{"{", 
         RowBox[{
          SuperscriptBox["10", 
           RowBox[{"-", "9"}]], ",", 
          SuperscriptBox["10", 
           RowBox[{"-", "7"}]]}], "}"}]}], ",", 
       RowBox[{"Log", "@", 
        RowBox[{"{", 
         RowBox[{
          SuperscriptBox["10", 
           RowBox[{"-", "13"}]], ",", 
          SuperscriptBox["10", 
           RowBox[{"-", "4"}]]}], "}"}]}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"FrameLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
      "f", ",", 
       "\"\<\!\(\*SubscriptBox[\(\[CapitalOmega]\), \
\(GW\)]\)\!\(\*SuperscriptBox[\(h\), \(2\)]\)\>\""}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"FrameTicks", "\[Rule]", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Log", "[", 
              SuperscriptBox["10", "n"], "]"}], ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"EvenQ", "[", "n", "]"}], ",", 
               StyleBox[
                RowBox[{"\"\<\\!\\(\\*SuperscriptBox[\\(10\\), \\(\>\"", "<>", 
                 RowBox[{"ToString", "[", "n", "]"}], "<>", 
                 "\"\<\\)]\\)\>\""}],
                ShowSpecialCharacters->False,
                ShowStringCharacters->True,
                NumberMarks->True], 
               StyleBox[",",
                ShowSpecialCharacters->False,
                ShowStringCharacters->True,
                NumberMarks->True], 
               StyleBox["\"\<\>\"",
                ShowSpecialCharacters->False,
                ShowStringCharacters->True,
                NumberMarks->True]}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", 
             RowBox[{"-", "12"}], ",", 
             RowBox[{"-", "4"}]}], "}"}]}], "]"}], "\[IndentingNewLine]", ",",
          "\[IndentingNewLine]", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Log", "[", 
              SuperscriptBox["10", "n"], "]"}], ",", 
             TagBox[
              StyleBox["\"\<\>\"",
               ShowSpecialCharacters->False,
               ShowStringCharacters->True,
               NumberMarks->True],
              FullForm]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", 
             RowBox[{"-", "12"}], ",", 
             RowBox[{"-", "4"}], ",", "2"}], "}"}]}], "]"}]}], 
        "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Log", "[", 
              RowBox[{"n", "*", 
               SuperscriptBox["10", 
                RowBox[{"-", "9"}]]}], "]"}], ",", 
             StyleBox[
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"MemberQ", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"1", ",", "10", ",", "100"}], "}"}], ",", "n"}], 
                 "]"}], ",", 
                RowBox[{"\"\<\\!\\(\\*SuperscriptBox[\\(10\\), \\(-\>\"", "<>", 
                 RowBox[{"ToString", "@", 
                  RowBox[{"Round", "@", 
                   RowBox[{"Abs", "@", 
                    RowBox[{"Log", "[", 
                    RowBox[{"10", ",", 
                    RowBox[{"n", "*", 
                    SuperscriptBox["10", 
                    RowBox[{"-", "9"}]]}]}], "]"}]}]}]}], "<>", 
                 "\"\<\\)]\\)\>\""}], ",", "\"\<\>\""}], "]"}],
              ShowSpecialCharacters->False,
              ShowStringCharacters->True,
              NumberMarks->True]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "xnList"}], "}"}]}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Log", "[", 
              RowBox[{"n", "*", 
               SuperscriptBox["10", 
                RowBox[{"-", "9"}]]}], "]"}], ",", 
             TagBox[
              StyleBox["\"\<\>\"",
               ShowSpecialCharacters->False,
               ShowStringCharacters->True,
               NumberMarks->True],
              FullForm]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "xnList"}], "}"}]}], "]"}]}], 
        "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotRangePadding", "->", "None"}], ",", 
    RowBox[{"AxesOrigin", "->", 
     RowBox[{"Log", "@", 
      RowBox[{"{", 
       RowBox[{
        SuperscriptBox["10", 
         RowBox[{"-", "9"}]], ",", 
        SuperscriptBox["10", 
         RowBox[{"-", "13"}]]}], "}"}]}]}], ",", 
    RowBox[{"BaseStyle", "\[Rule]", 
     RowBox[{"FontSize", "\[Rule]", "24"}]}], ",", 
    RowBox[{"FrameStyle", "\[Rule]", 
     RowBox[{"FontFamily", "\[Rule]", "\"\<Times\>\""}]}], ",", 
    RowBox[{"LabelStyle", "\[Rule]", 
     InterpretationBox[
      ButtonBox[
       TooltipBox[
        GraphicsBox[{
          {GrayLevel[0], RectangleBox[{0, 0}]}, 
          {GrayLevel[0], RectangleBox[{1, -1}]}, 
          {GrayLevel[0], RectangleBox[{0, -1}, {2, 1}]}},
         AspectRatio->1,
